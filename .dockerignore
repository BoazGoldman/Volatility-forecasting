# NOTE:
# Docker only reads `.dockerignore` from the build context root (this repo root).
# We keep an identical copy at `docker/.dockerignore` for organization.
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

web/node_modules/
web/dist/

data/*.db
data/*.db-*

.git/
.gitignore
